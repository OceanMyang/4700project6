#!/usr/bin/env -S python3 -u

import argparse, socket, time, json, select, struct, sys, math
from dnslib import DNSRecord, DNSHeader, RR, QTYPE, A, RCODE, DNSLabel

class Server:
    def __init__(self, root_ip, zone, port):
        self.root_ip = root_ip

        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.socket.bind(("0.0.0.0", port))
        self.port = self.socket.getsockname()[1]

        self.udp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.pending = {}

        self.log("Bound to port %d" % self.port)

        with open(zone, "r") as f:
            zone_data = f.read()

        self.records = {}
        for record in RR.fromZone(zone_data):
            self.log(str(record))
            if QTYPE[record.rtype] == "SOA":
                self.domain = record.rname
            key = str(record.rname)
            if key not in self.records:
                self.records[key] = []
            self.records[key].append(record)
        self.log("Domain name: %s" % self.domain)

    def log(self, message):
        sys.stderr.write(message + "\n")
        sys.stderr.flush()

    def send(self, addr, message):
        self.log("Sending message:\n%s" % message)
        self.socket.sendto(message.pack(), addr)

    def recv(self, socket):
        data, addr = socket.recvfrom(65535)
        record = DNSRecord.parse(data)
        self.log("Received message:\n%s" % record)
        return record, addr

    def compare_types(self, type1, type2):
        if type1 in [QTYPE.A, QTYPE.CNAME]:
            return type2 in [QTYPE.A, QTYPE.CNAME]
        else:
            return type1 == type2

    def find_local_records(self, qname, qtype=None, glues=None):
        matches = []
        key = str(qname)
        for record in self.records.get(key, []):
            if qtype and not self.compare_types(qtype, record.rtype):
                continue
            matches.append(record)
            if record.rtype == QTYPE.CNAME:
                matches.extend(self.find_local_records(record.rdata.label))
            if record.rtype == QTYPE.NS and glues is not None:
                glues.extend(self.find_local_records(record.rdata.label))
        return matches

    def forward(self, ip, qname, qtype, addr, original, cnames=None, bailiwick=None):
        request = DNSRecord.question(qname, QTYPE[qtype])
        bailiwick = bailiwick or DNSLabel(".")  # root: allow everything
        self.pending[request.header.id] = (addr, original, qname, qtype, cnames or [], bailiwick)
        self.udp_socket.sendto(request.pack(), (ip, 53))

    def find_next_ip(self, response):
        next_ip = None
        for rr in response.ar:
            if rr.rtype == QTYPE.A:
                next_ip = str(rr.rdata)
                break

        if not next_ip:
            for rr in response.auth:
                if rr.rtype == QTYPE.NS:
                    ns_ip_records = self.find_local_records(str(rr.rdata.label))
                    if ns_ip_records:
                        next_ip = str(ns_ip_records[0].rdata)
                        break
        return next_ip

    def resolve_global(self, response):
        if response.header.id not in self.pending:
            return
        
        addr, original, qname, qtype, cnames, bailiwick = self.pending.pop(response.header.id)

        # Bailiwick check — drop records outside the current zone
        # Empty bailiwick label = root, everything is allowed
        if bailiwick.label:
            response.rr   = [rr for rr in response.rr   if rr.rname.matchSuffix(bailiwick)]
            response.auth = [rr for rr in response.auth  if rr.rname.matchSuffix(bailiwick)]
            response.ar   = [rr for rr in response.ar    if rr.rname.matchSuffix(bailiwick)]

        # final answer: has answer records OR authoritative auth records
        if len(response.rr) > 0 or response.header.aa:
            
            # check if answer is an unresolved CNAME
            if len(response.rr) == 1 and response.rr[0].rtype == QTYPE.CNAME and qtype == QTYPE.A:
                cnames.append(response.rr[0])
                cname_target = response.rr[0].rdata.label
                self.forward(self.root_ip, cname_target, qtype, addr, original, cnames)
                return

            reply = original.reply()
            reply.header.aa = False
            reply.header.ra = 1
            for record in cnames:
                reply.add_answer(record)
            for record in response.rr:
                reply.add_answer(record)
            for record in response.auth:
                reply.add_auth(record)
            for record in response.ar:
                reply.add_ar(record)
            self.send(addr, reply)
            return

        next_ip = self.find_next_ip(response)

        if next_ip:
            # Narrow bailiwick to the zone from the auth NS records
            new_bailiwick = bailiwick
            for rr in response.auth:
                if rr.rtype == QTYPE.NS:
                    new_bailiwick = rr.rname  # e.g. DNSLabel('google.com.')
                    break
            self.forward(next_ip, qname, qtype, addr, original, cnames, new_bailiwick)
        else:
            reply = original.reply()
            reply.header.aa = False
            reply.header.ra = 1
            self.send(addr, reply)

    def run(self):
        seq = 0
        while True:
            socks = select.select([self.socket, self.udp_socket], [], [], 0.1)[0]
            for conn in socks:
                if conn is self.socket:
                    request, addr = self.recv(conn)
                    
                    for q in request.questions:
                        if q.qname.matchSuffix(self.domain):
                            response = request.reply()
                            glues = []
                            matches = self.find_local_records(q.qname, q.qtype, glues)
                            if matches:
                                for record in matches:
                                    response.add_answer(record)
                                for record in glues:
                                    response.add_ar(record)
                            else:
                                response.header.rcode = RCODE.NXDOMAIN
                            self.send(addr, response)
                        else:
                            self.forward(self.root_ip, q.qname, q.qtype, addr, request)

                elif conn is self.udp_socket:
                    dns_response, _ = self.recv(conn)
                    self.resolve_global(dns_response)
        return

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='send data')
    parser.add_argument('root_ip', type=str, help="The IP address of the root server")
    parser.add_argument('zone', type=str, help="The zone file for this server")
    parser.add_argument('--port', type=int, help="The port this server should bind to", default=0)
    args = parser.parse_args()
    sender = Server(args.root_ip, args.zone, args.port)
    sender.run()